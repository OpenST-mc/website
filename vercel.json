{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/archive/(.*).(litematic|webp|png|jpg)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/Extra-Function/(.*).js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/share/:subid",
      "destination": "/api/share?id=:subid"
    }
  ]
}